# ─── Database (Set in Vercel Dashboard → Settings → Environment Variables) ───
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/royal-academy

# ─── JWT Secrets (generate strong random strings for production) ──────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── API (keep as /api for Vercel - Next.js handles routing) ─────────────────
NEXT_PUBLIC_API_URL=/api
